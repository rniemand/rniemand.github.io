---
layout: layouts/base.njk
---
{# Only include the syntax highlighter CSS on blog posts, included with the CSS per-page bundle #}
<style>{% include "node_modules/prismjs/themes/prism-okaidia.css" %}</style>
<style>{% include "css/prism-diff.css" %}</style>

<article class="post-article">
  <header class="post-header">
    <h1 class="post-title">{{ title }}</h1>
    <div class="post-meta-bar">
      <span class="post-date-badge">
        <i class="bi bi-calendar2 me-1"></i>
        <time datetime="{{ page.date | htmlDateString }}">{{ page.date | readableDate }}</time>
      </span>
      {%- if tags | filterTagList | length > 0 %}
      <div class="post-tag-row">
        {%- for tag in tags | filterTagList %}
        {%- set tagUrl %}/tags/{{ tag | slugify }}/{% endset %}
        <a href="{{ tagUrl }}" class="post-tag-pill">{{ tag }}</a>
        {%- endfor %}
      </div>
      {%- endif %}
    </div>
  </header>

  {%- if content | toc %}
  <div class="post-content-grid">
    <aside class="post-toc-sidebar" aria-label="Table of contents">
      <p class="post-toc-label"><i class="bi bi-list-nested me-2"></i>Contents</p>
      {{ content | toc | safe }}
    </aside>
    <div class="post-body">
      {{ content | safe }}
    </div>
  </div>
  {%- else %}
  <div class="post-body">
    {{ content | safe }}
  </div>
  {%- endif %}

  {%- if collections.posts %}
  {%- set previousPost = collections.posts | getPreviousCollectionItem %}
  {%- set nextPost = collections.posts | getNextCollectionItem %}
  {%- if nextPost or previousPost %}
  <nav class="post-nav" aria-label="Post navigation">
    {%- if previousPost %}
    <a href="{{ previousPost.url }}" class="post-nav-item post-nav-prev">
      <span class="post-nav-dir"><i class="bi bi-arrow-left me-1"></i>Previous</span>
      <span class="post-nav-title">{{ previousPost.data.title }}</span>
    </a>
    {%- else %}
    <div></div>
    {%- endif %}
    {%- if nextPost %}
    <a href="{{ nextPost.url }}" class="post-nav-item post-nav-next">
      <span class="post-nav-dir">Next<i class="bi bi-arrow-right ms-1"></i></span>
      <span class="post-nav-title">{{ nextPost.data.title }}</span>
    </a>
    {%- endif %}
  </nav>
  {%- endif %}
  {%- endif %}
</article>

<script>{% include "js/post.js" %}</script>
