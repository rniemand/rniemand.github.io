<!doctype html>
<html lang="{{ metadata.language }}" class="h-100">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title or metadata.title }}</title>
    <meta
    name="description" content="{{ description or metadata.description }}">
    {# <link rel="alternate" href="/feed/feed.xml" type="application/atom+xml" title="{{ metadata.title }}"> #}
    <style>{% include "css/theme.css" %}</style>
    <link rel="stylesheet" href="//cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <meta name="generator" content="{{ eleventy.generator }}">
    <style>{% include "css/index.css" %}</style>
    {#- Render the CSS bundle using inlined CSS (for the fastest site performance in production) #}
    <style>{% getBundle "css" %}</style>
    <script type="module">{% include "node_modules/@zachleat/heading-anchors/heading-anchors.js" %}</script>
    {# <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1689302880129363" crossorigin="anonymous"></script> #}
  </head>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-HRDC8SXRVG"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag() {
      dataLayer.push(arguments);
    }
    gtag('js', new Date());
    gtag('config', 'G-HRDC8SXRVG');
  </script>
  <body class="d-flex flex-column h-100">
    <header>
      <nav class="navbar navbar-expand-md navbar-dark fixed-top bg-dark">
        <div class="container-fluid">
          <a class="navbar-brand {% if '/' == page.url %}active{% endif %}" href="/"><i class="bi bi-house-fill me-1"></i>RichardN</a>
          <button
            class="navbar-toggler"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#navbarCollapse"
            aria-controls="navbarCollapse"
            aria-expanded="false"
            aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="navbarCollapse">
            <ul class="navbar-nav me-auto mb-2 mb-md-0">
              {%- for entry in collections.all | eleventyNavigation %}
                <li class="nav-item">
                  <a class="nav-link {% if entry.url == page.url %}active{% endif %}" href="{{ entry.url }}">
                    {%- if entry.key == "Projects" %}<i class="bi bi-folder2-open me-1"></i>
                    {%- elif entry.key == "Tags" %}<i class="bi bi-tags-fill me-1"></i>
                    {%- elif entry.key == "Archive" %}<i class="bi bi-journal-text me-1"></i>
                    {%- elif entry.key == "About" %}<i class="bi bi-person-fill me-1"></i>
                    {%- else %}<i class="bi bi-link-45deg me-1"></i>
                    {%- endif %}{{ entry.title }}</a>
                </li>
              {%- endfor %}
            </ul>
          </div>
        </div>
      </nav>
    </header>
    <main class="flex-shrink-0 pt-3">
      <div class="container main-content pb-3">
        {{ content | safe }}
      </div>
    </main>
    <footer class="footer mt-auto py-1 bg-dark">
      <div class="container text-end">
        <a href="https://github.com/rniemand" target="_blank" rel="noopener noreferrer" class="btn btn-sm about-btn-github">
          <i class="bi bi-github me-1"></i>rniemand
        </a>
      </div>
    </footer>
    <!-- This page `{{ page.url }}` was built on {% currentBuildDate %} -->
    <script type="module" src="{% getBundleFileUrl "js" %}"></script>
    <script src="//cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>
    <script eleventy:ignore>
      document.querySelectorAll('.main-content table:not(.skip-auto-class)').forEach(function(t) {
        if (t.closest('.table-wrap')) return;
        var wrap = document.createElement('div');
        wrap.className = 'table-wrap';
        t.parentNode.insertBefore(wrap, t);
        wrap.appendChild(t);
      });
    </script>
    <script id="dsq-count-scr" src="//richardn-ca.disqus.com/count.js" async></script>
    <script eleventy:ignore>
    (function() {
      var KONAMI = [38,38,40,40,37,39,37,39,66,65];
      var pos = 0;
      document.addEventListener('keydown', function(e) {
        if (e.keyCode === KONAMI[pos]) {
          pos++;
          if (pos === KONAMI.length) {
            pos = 0;
            launchFireworks();
          }
        } else {
          pos = e.keyCode === KONAMI[0] ? 1 : 0;
        }
      });

      function launchFireworks() {
        var canvas = document.createElement('canvas');
        canvas.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:99999';
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
        document.body.appendChild(canvas);
        var ctx = canvas.getContext('2d');
        var particles = [];
        var start = null;
        var duration = 4500;

        function Particle(x, y, color) {
          var angle = Math.random() * Math.PI * 2;
          var speed = 2 + Math.random() * 5;
          this.x = x;
          this.y = y;
          this.vx = Math.cos(angle) * speed;
          this.vy = Math.sin(angle) * speed - 2;
          this.alpha = 1;
          this.color = color;
          this.radius = 2 + Math.random() * 2;
          this.gravity = 0.12;
          this.decay = 0.013 + Math.random() * 0.01;
        }
        Particle.prototype.update = function() {
          this.vy += this.gravity;
          this.x += this.vx;
          this.y += this.vy;
          this.alpha -= this.decay;
          this.vx *= 0.98;
        };
        Particle.prototype.draw = function(ctx) {
          ctx.save();
          ctx.globalAlpha = Math.max(0, this.alpha);
          ctx.beginPath();
          ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
          ctx.fillStyle = this.color;
          ctx.fill();
          ctx.restore();
        };

        var palette = ['#e83283','#39cbfb','#ffd97f','#f0ff7f','#b2fde7','#c3e6ff','#ff6b6b','#ffffff'];
        var nextBurst = 0;
        var burstInterval = 350;

        function burst() {
          var x = 80 + Math.random() * (canvas.width - 160);
          var y = 60 + Math.random() * (canvas.height * 0.6);
          var color = palette[Math.floor(Math.random() * palette.length)];
          for (var i = 0; i < 70; i++) {
            particles.push(new Particle(x, y, color));
          }
        }

        function tick(ts) {
          if (!start) start = ts;
          var elapsed = ts - start;
          ctx.clearRect(0, 0, canvas.width, canvas.height);
          if (elapsed > nextBurst && elapsed < duration - 600) {
            burst();
            nextBurst += burstInterval;
          }
          particles = particles.filter(function(p) { return p.alpha > 0; });
          particles.forEach(function(p) { p.update(); p.draw(ctx); });
          if (elapsed < duration || particles.length) {
            requestAnimationFrame(tick);
          } else {
            canvas.remove();
          }
        }

        requestAnimationFrame(tick);
      }
    })();
    </script>
  </body>
</html>